# Copy to `.env.production` before `npm run build` (see root .gitignore).
# Values are embedded at build time by Vite.

# Main site (browser)
VITE_SITE_URL=https://shivadevifoundation.org

# Backend API base (must end with /api as used in this project)
# Same domain + reverse proxy to Node:
#   VITE_API_URL=https://shivadevifoundation.org/api
# Hosted backend (e.g. Render):
#   VITE_API_URL=https://YOUR-SERVICE.onrender.com/api

VITE_API_URL=https://shivadevifoundation.org/api
