# Copy to .env and fill secrets. Never commit .env.

PORT=5001
NODE_ENV=development

# Public website (emails, links). Production: https://shivadevifoundation.org
FRONTEND_URL=https://shivadevifoundation.org

# Optional: extra allowed browser origins for CORS (comma-separated)
# CORS_ORIGINS=https://preview-xyz.vercel.app

MONGO_URI=
JWT_SECRET=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

API_PRIVATE=true
API_PUBLIC_PATHS=/admin/login,/posts,/events,/programs
